PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ekafy
DB_PASSWORD=change-me
DB_NAME=ekafy
DB_ADMIN_HOST=127.0.0.1
DB_ADMIN_PORT=3306
DB_ADMIN_USER=ekafy_admin
DB_ADMIN_PASSWORD=change-me-admin

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
ALLOW_REGISTRATION=false

# Service control is disabled by default so local development cannot accidentally
# run systemctl. Set to true only on the target Linux VPS.
ENABLE_SERVICE_CONTROL=false

# Managed project paths must stay inside this root.
PROJECTS_ROOT=/srv

# Used by Certbot when provisioning Let's Encrypt certificates for project domains.
SSL_EMAIL=admin@example.com

# Keep false for Cloudflare Full (strict). Set true only for local/dev testing.
ALLOW_SELF_SIGNED_SSL=false

# Default PHP-FPM socket for PHP, WordPress, and WooCommerce projects.
PHP_FPM_SOCKET=/run/php/php8.1-fpm.sock
