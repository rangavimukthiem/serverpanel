PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ekafy
DB_PASSWORD=change-me
DB_NAME=ekafy

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
ALLOW_REGISTRATION=false

# Service control is disabled by default so local development cannot accidentally
# run systemctl. Set to true only on the target Linux VPS.
ENABLE_SERVICE_CONTROL=false
